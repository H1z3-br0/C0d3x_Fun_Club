# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# CLIProxyAPI — local OpenAI-compatible proxy that fans out to upstream
# OAuth-backed providers (Codex, Claude, Gemini). Start it first:
#   /home/dima/cliproxyapi/cli-proxy-api --config /home/dima/cliproxyapi/config.yaml
#
# OPENAI_BASE_URL — must match `port` in cliproxyapi/config.yaml (default 8317).
# CLIPROXY_API_KEY — CLIENT-SIDE access key to the local proxy; one of the
#                   entries under `api-keys:` in cliproxyapi/config.yaml.
#                   This is NOT an OpenAI/Anthropic/Gemini key — upstream
#                   credentials live inside ~/.cli-proxy-api/*.json (OAuth).
# OPENAI_API_KEY is accepted as a legacy alias for CLIPROXY_API_KEY.
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
CLIPROXY_API_KEY=sk-paste-one-of-the-keys-from-cliproxyapi-config-yaml
